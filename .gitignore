# FPGA LPU Project — .gitignore

# Quartus / FPGA build artifacts
output_files/
db/
incremental_db/
*.qws
*.sopcinfo
*.sopc
*.sof
*.pof
*.jdi
*.rpt
*.summary
*.pin
*.done
*.qar
*.qarlog
*.qdf
*.stp

# Icarus Verilator simulation build
rtl/sim/build/*.vvp
rtl/sim/*.vvp
*.vcd
*.lxt
*.lxt2
*.fst
*.wlf
*.log
transcript
work/

# Verilator build artifacts
rtl/sim/verilator/obj_dir*/
rtl/sim/verilator/*.exe
rtl/sim/verilator/*.o

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Claude Code internal (except shared team AI role configs)
.claude/*
!.claude/roles/

# Temp files
/tmp/
*.tmp

# Large binaries (PPT, PDF — keep only source documents)
*.ppt
*.pptx
*.pdf
*.docx
*.doc

# Node.js
node_modules/
