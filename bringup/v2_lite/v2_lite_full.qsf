# ============================================================================
# v2_lite_full.qsf — PCIe Gen3x16 + HBM2 + FFN (Triple Merge)
# Generated: 2026-06-10, Quartus Prime Pro 26.1
# ============================================================================
set_global_assignment -name TOP_LEVEL_ENTITY v2_lite_full
set_global_assignment -name LAST_QUARTUS_VERSION "26.1.0 Pro Edition"
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name DEVICE 1SM21BHU2F53E1VG
set_global_assignment -name FAMILY "Stratix 10"
set_global_assignment -name MIN_CORE_JUNCTION_TEMP 0
set_global_assignment -name MAX_CORE_JUNCTION_TEMP 100
set_global_assignment -name ERROR_CHECK_FREQUENCY_DIVISOR 256
set_global_assignment -name EDA_SIMULATION_TOOL "<None>"
set_global_assignment -name EDA_OUTPUT_DATA_FORMAT NONE -section_id eda_simulation

# ============================================================================
# Clock Pin Assignments (Shared)
# ============================================================================
set_location_assignment PIN_AU17 -to core_clk_iopll_ref_clk_clk -comment "100MHz core clock (shared)"
set_location_assignment PIN_AU16 -to "core_clk_iopll_ref_clk_clk(n)" -comment "100MHz core clock N"
set_instance_assignment -name IO_STANDARD LVDS -to core_clk_iopll_ref_clk_clk

# HBM2 PLL refclk
set_location_assignment PIN_P27 -to hbm_0_example_design_pll_ref_clk_clk -comment "HBM2 PLL refclk"
set_location_assignment PIN_R27 -to "hbm_0_example_design_pll_ref_clk_clk(n)" -comment "HBM2 PLL refclk N"
set_instance_assignment -name IO_STANDARD LVDS -to hbm_0_example_design_pll_ref_clk_clk

# 50MHz clock (PCIe)
set_location_assignment PIN_BE17 -to clk_50m
set_instance_assignment -name IO_STANDARD LVDS -to clk_50m

# PCIe refclk
set_location_assignment PIN_AW43 -to refclk_pcie_ep_p
set_location_assignment PIN_AW42 -to refclk_pcie_ep_n
set_location_assignment PIN_AR43 -to refclk_pcie_ep_edge_p
set_location_assignment PIN_AR42 -to refclk_pcie_ep_edge_n
set_location_assignment PIN_BA43 -to refclk_pcie_ep1_p
set_location_assignment PIN_BA42 -to refclk_pcie_ep1_n
set_instance_assignment -name IO_STANDARD LVDS -to refclk_pcie_ep_p
set_instance_assignment -name XCVR_REFCLK_PIN_TERMINATION AC_COUPLING -to refclk_pcie_ep_p

# ============================================================================
# Reset Input (Shared)
# ============================================================================
set_location_assignment PIN_BL14 -to cpu_resetn
set_instance_assignment -name IO_STANDARD "1.8 V" -to cpu_resetn

# ============================================================================
# LED Outputs (Shared)
# ============================================================================
set_location_assignment PIN_BG12 -to led[0] -comment "LED0: HBM2 TG pass"
set_location_assignment PIN_BF12 -to led[1] -comment "LED1: PCIe PLL status"
set_location_assignment PIN_BG11 -to led[2] -comment "LED2: FFN status"
set_location_assignment PIN_BH11 -to led[3] -comment "LED3: Heartbeat"
set_instance_assignment -name IO_STANDARD "1.8 V" -to led[0]
set_instance_assignment -name IO_STANDARD "1.8 V" -to led[1]
set_instance_assignment -name IO_STANDARD "1.8 V" -to led[2]
set_instance_assignment -name IO_STANDARD "1.8 V" -to led[3]

