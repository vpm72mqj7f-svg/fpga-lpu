# Top Module: v2_lite_full
#
# Comment out a line: (# or //#)
# Delimiter character: (%%)

##################################################################
#Common rules for register:
#Access types:
#R/W : Read / Write
#R/W/C: Read / Write 1 to clear (sticky bit)
#R_O: Read Only, No clear on read
#W_O: write only

##################################################################
#              Global Address Map                                 #
#              0x0000 - 0x0FFF: SYS / Global                     #
#              0x1000 - 0x1FFF: PCIe                             #
#              0x2000 - 0x2FFF: HBM2                             #
#              0x3000 - 0x3FFF: FFN                              #
#              0x4000 - 0xFFFF: Reserved                         #


##################################################################
#                                                                #
#   SYS Block Version                                             #
#                                                                #
##################################################################

// Register Full Name: SYS Block Version
// RTL Instant Name  : sys_version
// Address      : 0x0000
// Description  : SYS Block Version — day/month/year/number
// Width        : 32
// Register Type: {Status}
//  Field : [31:24]   %% day    %% Build day         %% R_O %% 0x0B  %% 0x0B
//  Field : [23:16]   %% month  %% Build month       %% R_O %% 0x06  %% 0x06
//  Field : [15:08]   %% year   %% Build year-2000   %% R_O %% 0x1A  %% 0x1A
//  Field : [07:00]   %% number %% Build number/day  %% R_O %% 0x01  %% 0x01

##################################################################
#                                                                #
#   Scratchpad Register (CPU Bus Test)                           #
#                                                                #
##################################################################

// Register Full Name: Scratchpad Register
// RTL Instant Name  : sys_scratch
// Address      : 0x0004
// Description  : Scratchpad — use to test CPU bus read/write
// Width        : 32
// Register Type: {Config}
//  Field : [31:00]   %% scratch %% Scratchpad value %% R/W %% 0x4154564E %% 0x4154564E

##################################################################
#                                                                #
#   SYS Control                                                   #
#                                                                #
##################################################################

// Register Full Name: SYS Control Register
// RTL Instant Name  : sys_control
// Address      : 0x0008
// Description  : System control: FFN start, reset, LED override
// Width        : 32
// Register Type: {Config|Status}
//  Field : [31:08]   %% Unused      %%                                 %%      %%       %%
//  Field : [07:04]   %% led_override %% LED override (1=force on)      %% R/W  %% 0x0   %% 0x0
//  Field : [03:03]   %% counter_rst  %% Reset FFN performance counters %% R/W/C %% 0x0   %% 0x0
//  Field : [02:02]   %% ffn_reset    %% FFN soft reset (1=reset)       %% R/W  %% 0x0   %% 0x0
//  Field : [01:01]   %% ffn_start    %% FFN start (pulse 0→1→0)        %% R/W  %% 0x0   %% 0x0
//  Field : [00:00]   %% Unused       %%                                 %%      %%       %%

##################################################################
#                                                                #
#   SYS Status                                                    #
#                                                                #
##################################################################

// Register Full Name: SYS Status Register
// RTL Instant Name  : sys_status
// Address      : 0x000C
// Description  : System status: LED state, PLL locks, reset state
// Width        : 32
// Register Type: {Status}
//  Field : [31:20]   %% Unused      %%                                     %%      %%       %%
//  Field : [19:19]   %% hbm_pll_lck %% HBM2 PLL locked                    %% R_O  %% 0x0   %% 0x0
//  Field : [18:18]   %% atx_pll_lck %% ATX PLL locked                     %% R_O  %% 0x0   %% 0x0
//  Field : [17:17]   %% pcie_link_up%% PCIe link up                        %% R_O  %% 0x0   %% 0x0
//  Field : [16:16]   %% config_done %% FPGA configuration done             %% R_O  %% 0x1   %% 0x1
//  Field : [15:04]   %% Unused      %%                                     %%      %%       %%
//  Field : [03:00]   %% led_state   %% Current LED state                   %% R_O  %% 0x0   %% 0x0


##################################################################
#              PCIe Registers (0x1000 - 0x1FFF)                   #
##################################################################

##################################################################
#                                                                #
#   PCIe Block Version                                            #
#                                                                #
##################################################################

// Register Full Name: PCIe Block Version
// RTL Instant Name  : pcie_version
// Address      : 0x1000
// Description  : PCIe Block Version
// Width        : 32
// Register Type: {Status}
//  Field : [31:24]   %% day    %% Build day         %% R_O %% 0x0B  %% 0x0B
//  Field : [23:16]   %% month  %% Build month       %% R_O %% 0x06  %% 0x06
//  Field : [15:08]   %% year   %% Build year-2000   %% R_O %% 0x1A  %% 0x1A
//  Field : [07:00]   %% number %% Build number/day  %% R_O %% 0x01  %% 0x01

##################################################################
#                                                                #
#   PCIe LTSSM State                                              #
#                                                                #
##################################################################

// Register Full Name: PCIe LTSSM State
// RTL Instant Name  : pcie_ltssm
// Address      : 0x1004
// Description  : Current LTSSM state from PCIe HIP
// Width        : 32
// Register Type: {Status}
//  Field : [31:06]   %% Unused      %%                                     %%      %%       %%
//  Field : [05:00]   %% ltssm_state %% 0=Detect 1=Poll 2=Config 3=L0 ...  %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   PCIe Link Status                                              #
#                                                                #
##################################################################

// Register Full Name: PCIe Link Status
// RTL Instant Name  : pcie_link_status
// Address      : 0x1008
// Description  : PCIe link speed, width, up status
// Width        : 32
// Register Type: {Status}
//  Field : [31:22]   %% Unused      %%                                     %%      %%       %%
//  Field : [21:16]   %% link_width  %% Negotiated link width (1/2/4/8/16)  %% R_O  %% 0x0   %% 0x0
//  Field : [15:12]   %% Unused      %%                                     %%      %%       %%
//  Field : [11:08]   %% link_speed  %% 1=Gen1 2=Gen2 3=Gen3                %% R_O  %% 0x0   %% 0x0
//  Field : [07:01]   %% Unused      %%                                     %%      %%       %%
//  Field : [00:00]   %% link_up     %% PCIe link is up (L0)                %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   PCIe PLL Lock Status (per-bank)                               #
#                                                                #
##################################################################

// Register Full Name: PCIe PLL Lock Status
// RTL Instant Name  : pcie_pll_status
// Address      : 0x100C
// Description  : Per-bank PLL lock status for all 16 lanes
// Width        : 32
// Register Type: {Status}
//  Field : [31:16]   %% Unused      %%                                     %%      %%       %%
//  Field : [15:00]   %% pll_locked  %% 1 per bank: PLL locked              %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   PCIe Error Counters                                           #
#                                                                #
##################################################################

// Register Full Name: PCIe Error Counters
// RTL Instant Name  : pcie_err_cnt
// Address      : 0x1010
// Description  : DL/TL error counters (sticky)
// Width        : 32
// Register Type: {Status}
//  Field : [31:24]   %% tl_err     %% Transaction Layer errors   %% R/W/C %% 0x0   %% 0x0
//  Field : [23:16]   %% dl_err     %% Data Link Layer errors     %% R/W/C %% 0x0   %% 0x0
//  Field : [15:08]   %% phy_err    %% Physical Layer errors      %% R/W/C %% 0x0   %% 0x0
//  Field : [07:00]   %% Unused     %%                             %%      %%       %%


