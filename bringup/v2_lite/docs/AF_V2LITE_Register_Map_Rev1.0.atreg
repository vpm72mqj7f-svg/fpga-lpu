// Register Full Name: FFN Block Version
// RTL Instant Name  : ffn_version
// Address      : 0x3000
// Description  : FFN Block Version
// Width        : 32
// Register Type: {Status}
//  Field : [31:24]   %% day    %% Build day         %% R_O %% 0x0B  %% 0x0B
//  Field : [23:16]   %% month  %% Build month       %% R_O %% 0x06  %% 0x06
//  Field : [15:08]   %% year   %% Build year-2000   %% R_O %% 0x1A  %% 0x1A
//  Field : [07:00]   %% number %% Build number/day  %% R_O %% 0x01  %% 0x01

##################################################################
#                                                                #
#   FFN Control                                                   #
#                                                                #
##################################################################

// Register Full Name: FFN Control Register
// RTL Instant Name  : ffn_control
// Address      : 0x3004
// Description  : FFN start, stop, reset control
// Width        : 32
// Register Type: {Config}
//  Field : [31:04]   %% Unused      %%                               %%      %%       %%
//  Field : [03:03]   %% counter_rst %% Reset perf counters (pulse)   %% R/W/C %% 0x0   %% 0x0
//  Field : [02:02]   %% soft_reset  %% FFN soft reset (active=1)     %% R/W  %% 0x0   %% 0x0
//  Field : [01:01]   %% stop        %% FFN stop (graceful)           %% R/W  %% 0x0   %% 0x0
//  Field : [00:00]   %% start       %% FFN start (pulse 0→1→0)       %% R/W  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   FFN Status                                                    #
#                                                                #
##################################################################

// Register Full Name: FFN Status Register
// RTL Instant Name  : ffn_status
// Address      : 0x3008
// Description  : FFN state, busy, done, pass
// Width        : 32
// Register Type: {Status}
//  Field : [31:16]   %% Unused      %%                               %%      %%       %%
//  Field : [15:08]   %% error_code  %% Error code (0=no error)       %% R_O  %% 0x0   %% 0x0
//  Field : [07:07]   %% pass        %% Last inference passed         %% R_O  %% 0x0   %% 0x0
//  Field : [06:06]   %% done        %% Inference complete            %% R_O  %% 0x0   %% 0x0
//  Field : [05:05]   %% busy        %% FFN is processing             %% R_O  %% 0x0   %% 0x0
//  Field : [04:04]   %% Unused      %%                               %%      %%       %%
//  Field : [03:00]   %% state       %% FSM state (0=IDLE 1=LOAD...)  %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   FFN Performance — Token Count                                 #
#                                                                #
##################################################################

// Register Full Name: FFN Token Counter
// RTL Instant Name  : ffn_token_cnt
// Address      : 0x300C
// Description  : Number of tokens processed since last counter reset
// Width        : 32
// Register Type: {Status}
//  Field : [31:00]   %% token_cnt   %% Token count                  %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   FFN Performance — Cycle Count                                 #
#                                                                #
##################################################################

// Register Full Name: FFN Cycle Counter
// RTL Instant Name  : ffn_cycle_cnt
// Address      : 0x3010
// Description  : Cycle count since last counter reset
// Width        : 32
// Register Type: {Status}
//  Field : [31:00]   %% cycle_cnt   %% Cycle count                  %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   FFN Performance — Throughput (TPS)                            #
#                                                                #
##################################################################

// Register Full Name: FFN Throughput
// RTL Instant Name  : ffn_tps
// Address      : 0x3014
// Description  : Calculated TPS = token_cnt × core_freq / cycle_cnt (×1e6)
// Width        : 32
// Register Type: {Status}
// Formula      : (token_cnt * 100000000) / cycle_cnt  // at 100MHz
//  Field : [31:00]   %% tps         %% Tokens per second estimate    %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   FFN AXI Transaction Counters                                  #
#                                                                #
##################################################################

// Register Full Name: FFN AXI Read Transaction Counter
// RTL Instant Name  : ffn_axi_ar_cnt
// Address      : 0x3018
// Description  : Number of AXI4 read address transactions issued
// Width        : 32
// Register Type: {Status}
//  Field : [31:16]   %% r_beat_cnt  %% Read data beats received     %% R_O  %% 0x0   %% 0x0
//  Field : [15:00]   %% ar_trans_cnt%% Read address transactions    %% R_O  %% 0x0   %% 0x0

##################################################################
#                                                                #
#   FFN DSP Status (GATE CHECK)                                   #
#                                                                #
##################################################################

// Register Full Name: FFN DSP Utilization
// RTL Instant Name  : ffn_dsp_status
// Address      : 0x301C
// Description  : DSP block count and status — GATE CHECK: DSP > 0
// Width        : 32
// Register Type: {Status}
//  Field : [31:16]   %% Unused      %%                               %%      %%       %%
//  Field : [15:00]   %% dsp_count   %% Number of DSP blocks used     %% R_O  %% 0x0   %% 0x0
//                                             %% GATE: MUST be > 0   %%
