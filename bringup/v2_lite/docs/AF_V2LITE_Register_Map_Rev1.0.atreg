//  Field : [23:16]   %% month  %% Build month       %% R_O %% 0x06  %% 0x06
//  Field : [15:08]   %% year   %% Build year-2000   %% R_O %% 0x1A  %% 0x1A
//  Field : [07:00]   %% number %% Build number/day  %% R_O %% 0x01  %% 0x01

