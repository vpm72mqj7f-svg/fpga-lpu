##################################################################

// Register Full Name: HBM2 Controller Status
// RTL Instant Name  : hbm2_status
// Address      : 0x200C
// Description  : HBM2 PLL lock, channel active, CATTRIP, temperature
// Width        : 32
// Register Type: {Status}
//  Field : [31:07]   %% Unused      %%                               %%      %%       %%
//  Field : [06:06]   %% ch_active   %% Any channel active            %% R_O  %% 0x0   %% 0x0
//  Field : [05:05]   %% pll_locked  %% HBM2 PLL locked               %% R_O  %% 0x0   %% 0x0
//  Field : [04:04]   %% cattrip     %% CATTRIP asserted              %% R_O  %% 0x0   %% 0x0
//  Field : [03:00]   %% temp_code   %% Temperature sensor code       %% R_O  %% 0x0   %% 0x0

