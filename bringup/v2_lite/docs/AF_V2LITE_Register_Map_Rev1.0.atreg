// Width        : 32
// Register Type: {Status}
//  Field : [31:16]   %% Unused      %%                               %%      %%       %%
//  Field : [15:00]   %% tg_timeout  %% TG timeout (1 per channel)    %% R_O %% 0x0   %% 0x0

