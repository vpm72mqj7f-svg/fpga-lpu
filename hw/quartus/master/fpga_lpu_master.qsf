# --------------------------------------------------------------------------- #
# fpga_lpu_master.qsf — Master FPGA Project (Production)
#
# Target:  Intel Agilex 7 M-Series AGM 039-F
# Board:   DK-DEV-AGM039EA
# Role:    PCIe Master (Chip 0) — host interface, DMA, KV offload, C2C ring origin
# --------------------------------------------------------------------------- #

QUARTUS_VERSION = "24.3"
PROJECT_REVISION = "fpga_lpu_master"
PROJECT_OUTPUT_DIRECTORY = output_files

# --------------------------------------------------------------------------- #
# Top-level entity
# --------------------------------------------------------------------------- #
set_global_assignment -name TOP_LEVEL_ENTITY top_master
set_global_assignment -name FAMILY "Agilex 7"
set_global_assignment -name DEVICE AGMF039R47A1E2VR0
# Production: AGMF039R47A1E1VC

# Production build — use full DeepSeek V4 parameters
set_global_assignment -name VERILOG_MACRO "FPGA_LPU_PRODUCTION"

# --------------------------------------------------------------------------- #
# Source files — Shared RTL (all compute + debug modules)
# --------------------------------------------------------------------------- #
source ../common/common_modules.qsf

# --------------------------------------------------------------------------- #
# Source files — Master-specific
# --------------------------------------------------------------------------- #
set_global_assignment -name SYSTEMVERILOG_FILE ../../hw/src/top_master.sv
set_global_assignment -name SYSTEMVERILOG_FILE ../../rtl/chip/kv_dma_engine.sv

# --------------------------------------------------------------------------- #
# Intel IP (generated by QSYS / Platform Designer)
# --------------------------------------------------------------------------- #
# R-Tile PCIe 5.0 x16 (Master only)
# set_global_assignment -name QSYS_FILE pcie_r_tile.qsys
# set_global_assignment -name SYSTEMVERILOG_FILE ../../hw/ip/pcie_r_tile/pcie_r_tile.sv

# HBM2e Controller (32 GB @ 920 GB/s)
# set_global_assignment -name QSYS_FILE hbm2e_ctrl.qsys
# set_global_assignment -name SYSTEMVERILOG_FILE ../../hw/ip/hbm2e_ctrl/hbm2e_ctrl.sv

# F-Tile C2C SerDes (dual ring)
# set_global_assignment -name QSYS_FILE c2c_f_tile.qsys
# set_global_assignment -name SYSTEMVERILOG_FILE ../../hw/ip/c2c_f_tile/c2c_f_tile.sv

# --------------------------------------------------------------------------- #
# SDC Constraints
# --------------------------------------------------------------------------- #
set_global_assignment -name SDC_FILE ../../hw/constraints/fpga_lpu.sdc

# --------------------------------------------------------------------------- #
# Pin Assignments (Master: PCIe + C2C + HBM)
# --------------------------------------------------------------------------- #
set_global_assignment -name SOURCE_TCL_FILE ../../hw/constraints/pin_assignment_master.tcl

# --------------------------------------------------------------------------- #
# Synthesis & Fitter — Production (aggressive)
# --------------------------------------------------------------------------- #
set_global_assignment -name OPTIMIZATION_MODE "PERFORMANCE"
set_global_assignment -name SYNTH_GATED_CLOCK_CONVERSION ON
set_global_assignment -name SYNTH_PROTECT_SDC_CONSTRAINT ON
set_global_assignment -name ROUTER_LCELL_INSERTION_AND_LOGIC_DUPLICATION ON
set_global_assignment -name ROUTER_TIMING_OPTIMIZATION_LEVEL MAXIMUM
set_global_assignment -name FITTER_EFFORT "STANDARD_FIT"
set_global_assignment -name PHYSICAL_SYNTHESIS_EFFORT NORMAL

# --------------------------------------------------------------------------- #
# Power
# --------------------------------------------------------------------------- #
set_global_assignment -name POWER_PRESET_COOLING_SOLUTION "HEAT_SINK_WITH_MEDIUM_AIRFLOW"
set_global_assignment -name POWER_BOARD_THERMAL_MODEL "DK_DEV_AGM039EA"

# --------------------------------------------------------------------------- #
# IP-specific (uncomment after QSYS generation)
# --------------------------------------------------------------------------- #
# set_global_assignment -name PCIE_REVISION "5.0"
# set_global_assignment -name PCIE_LANES 16
# set_global_assignment -name PCIE_REFCLK_FREQ "100 MHz"
# set_global_assignment -name HBM_STACK_HEIGHT 4
# set_global_assignment -name HBM_DATA_RATE "1800 MHz"
# set_global_assignment -name HBM_AXI_DATA_WIDTH 256
